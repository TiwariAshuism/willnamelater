# Local development key material. Generated, never committed.
deploy/dev-secrets/

# --- Production secrets -------------------------------------------------------
#
# READ THIS BEFORE ADDING ANYTHING HERE.
#
# deploy/secrets/prod.enc.env IS COMMITTED, and that is correct: SOPS encrypts the
# VALUES and leaves the KEYS in plaintext, so a diff shows WHICH secret rotated
# without revealing any of them. Do not add it below.
#
# The danger is the honest mistake: copy prod.enc.env.example, fill in real values,
# forget to `sops --encrypt`, commit plaintext credentials. A .gitignore CANNOT catch
# that — the encrypted and unencrypted files have the same name. The guard is
# `make secrets-check` (also run in CI), which asserts the file actually carries SOPS
# metadata. Run it before you commit, or let the pre-commit hook do it:
#     git config core.hooksPath .githooks

# age PRIVATE keys. The half that decrypts everything. Never in git, ever.
*.age.key
*.agekey
age.key
.age.key
deploy/secrets/*.key

# Any obviously-plaintext staging area for secrets.
deploy/secrets/*.dec.env
deploy/secrets/*.plain.env
deploy/secrets/*.decrypted*

# Database dumps. backup.sh streams straight to object storage and never writes one,
# but a manual pg_dump run from the repo root would land here.
*.dump
*.dump.age
*.sql.gz

# Terraform
#
# .terraform/ is a provider cache — regenerated by `terraform init`, machine-specific,
# hundreds of MB. Ignored.
#
# .terraform.lock.hcl is deliberately NOT ignored. It pins the exact provider versions
# and hashes that were validated, so CI cannot silently resolve a different provider
# than the one the configuration was checked against. It belongs in git for the same
# reason pnpm-lock.yaml does.
**/.terraform/
*.tfstate
*.tfstate.*
crash.log

# Real variable values (project ids, account ids, keys). The .example files are the
# committed template.
*.tfvars
!*.tfvars.example

# tflint provider plugin cache (regenerated by `tflint --init`)
.tflint-plugins/
