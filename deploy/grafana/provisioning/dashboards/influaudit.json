{
  "uid": "influaudit-overview",
  "title": "InfluAudit — Overview",
  "description": "The four golden signals plus the two things that actually take this system down: the queue backing up, and the VM's disk filling with Docker images.",
  "tags": ["influaudit"],
  "timezone": "utc",
  "refresh": "30s",
  "schemaVersion": 39,
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "type": "row",
      "title": "Traffic & Errors",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "type": "timeseries",
      "title": "Request rate by status",
      "description": "Traffic. A cliff here with no deploy behind it means DNS or Caddy, not the app.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "targets": [
        {
          "expr": "sum by (http_status_code) (rate(http_server_request_duration_count[5m]))",
          "legendFormat": "{{http_status_code}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "fillOpacity": 10 } },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "5xx rate",
      "description": "Errors. This is the panel an alert fires on — see provisioning/alerting.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "targets": [
        {
          "expr": "sum(rate(http_server_request_duration_count{http_status_code=~\"5..\"}[5m]))",
          "legendFormat": "5xx"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "fillOpacity": 20 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.1 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Latency (p50 / p95 / p99)",
      "description": "Latency. p99 detaching from p50 while traffic is flat is almost always the database or a third-party API, not the app.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 9 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(http_server_request_duration_bucket[5m])))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_request_duration_bucket[5m])))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_server_request_duration_bucket[5m])))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    },
    {
      "type": "row",
      "title": "Saturation — the two things that actually kill this box",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 }
    },
    {
      "type": "timeseries",
      "title": "Disk free (root)",
      "description": "THE most common way a single-VM deployment dies: Docker images and container logs fill the disk, Postgres connections start failing, and nothing in the application logs explains why. deploy.sh prunes images older than a week; this is the panel that tells you it is not enough.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 18 },
      "targets": [
        {
          "expr": "node_filesystem_avail_bytes{mountpoint=\"/host\",fstype!=\"tmpfs\"}",
          "legendFormat": "available"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 5000000000 },
              { "color": "green", "value": 15000000000 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Memory available",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 18 },
      "targets": [
        {
          "expr": "node_memory_MemAvailable_bytes",
          "legendFormat": "available"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] }
    },
    {
      "type": "timeseries",
      "title": "Load average (1m)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 18 },
      "targets": [{ "expr": "node_load1", "legendFormat": "load1" }],
      "fieldConfig": { "defaults": {}, "overrides": [] }
    },
    {
      "type": "row",
      "title": "Logs",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 26 }
    },
    {
      "type": "logs",
      "title": "Errors across every service",
      "description": "Loki. If this panel is EMPTY the pipeline is broken, not the system healthy — promtail is what fills it (see promtail.yml). An empty log panel is the failure that looks like success.",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 27 },
      "targets": [
        {
          "expr": "{service=~\"api|worker|ml|web\"} |= \"\" | json | level =~ \"ERROR|error\"",
          "queryType": "range"
        }
      ],
      "options": { "showTime": true, "wrapLogMessage": true, "sortOrder": "Descending" }
    }
  ]
}
