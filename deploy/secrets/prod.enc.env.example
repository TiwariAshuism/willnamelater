# The shape of deploy/secrets/prod.enc.env.
#
# THIS FILE IS THE TEMPLATE, IN PLAINTEXT, WITH NO REAL VALUES. The real file is
# prod.enc.env — SOPS-encrypted, committed to git, and never in plaintext on disk.
#
# Create it:
#   cp deploy/secrets/prod.enc.env.example deploy/secrets/prod.enc.env
#   # fill in real values
#   sops --encrypt --in-place deploy/secrets/prod.enc.env
#
# Edit it (decrypts to a temp file, re-encrypts on save):
#   make secrets-edit
#
# deploy.sh decrypts it to a tmpfs on the VM at deploy time and removes it once
# compose has read it. It is never written to a disk unencrypted, anywhere.

# --- Managed data tier -------------------------------------------------------
# sslmode=require is mandatory: config.Validate rejects sslmode=disable in prod.
INFLUAUDIT_POSTGRES__DSN=postgres://influaudit:REPLACE@REPLACE:5432/influaudit?sslmode=require
INFLUAUDIT_REDIS__ADDR=REPLACE:6380
INFLUAUDIT_REDIS__PASSWORD=REPLACE

# --- Public origins ----------------------------------------------------------
# Must be https and must not be localhost — config.Validate checks the VALUE, not
# just presence, because the default IS localhost and would otherwise sail through.
INFLUAUDIT_HTTP__PUBLIC_BASE_URL=https://api.influaudit.com
APP_BASE_URL=https://app.influaudit.com
API_DOMAIN=api.influaudit.com
APP_DOMAIN=app.influaudit.com
ACME_EMAIL=ops@influaudit.com

# --- Object storage (Cloudflare R2 by default) -------------------------------
# Deliberately NOT on the compute cloud, so it is not part of a cloud migration.
INFLUAUDIT_STORAGE__ENDPOINT=https://REPLACE.r2.cloudflarestorage.com
INFLUAUDIT_STORAGE__REGION=auto
INFLUAUDIT_STORAGE__BUCKET=influaudit
INFLUAUDIT_STORAGE__ACCESS_KEY=REPLACE
INFLUAUDIT_STORAGE__SECRET_KEY=REPLACE

# --- Crypto ------------------------------------------------------------------
# openssl rand -base64 32
#
# ⚠ THIS KEY SEALS OAUTH TOKENS AT REST. It cannot be rotated without re-encrypting
# the oauth_connections table. CARRY IT UNCHANGED ACROSS A CLOUD MIGRATION — it is
# the one piece of production state that lives in neither Postgres nor object
# storage. See deploy/MIGRATION.md.
INFLUAUDIT_CRYPTO__MASTER_KEY=REPLACE

# --- JWT signing (RS256), inline. No .pem on disk in prod. -------------------
# openssl genrsa 2048 | sed -z 's/\n/\\n/g'
INFLUAUDIT_JWT__PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\nREPLACE\n-----END PRIVATE KEY-----"

# --- Third-party services ----------------------------------------------------
INFLUAUDIT_ANTHROPIC__API_KEY=sk-ant-REPLACE
INFLUAUDIT_ML__SERVICE_TOKEN=REPLACE
INFLUAUDIT_RAZORPAY__KEY_ID=rzp_live_REPLACE
INFLUAUDIT_RAZORPAY__KEY_SECRET=REPLACE
INFLUAUDIT_RAZORPAY__WEBHOOK_SECRET=REPLACE

# --- Transactional mail ------------------------------------------------------
# Any SMTP relay. Postmark or Resend recommended: both are cloud-independent.
# Deliberately NOT SES — it needs an AWS IAM identity, which is exactly the kind of
# "small" coupling that turns a two-day migration into a two-week one.
INFLUAUDIT_EMAIL__HOST=smtp.postmarkapp.com
INFLUAUDIT_EMAIL__PORT=587
INFLUAUDIT_EMAIL__USERNAME=REPLACE
INFLUAUDIT_EMAIL__PASSWORD=REPLACE
INFLUAUDIT_EMAIL__FROM=reports@influaudit.com
INFLUAUDIT_EMAIL__FROM_NAME=InfluAudit
INFLUAUDIT_EMAIL__TLS=starttls

# --- Connector credentials (referenced BY NAME from connectors.yaml) ---------
YT_API_KEY=REPLACE
YT_OAUTH_CLIENT_ID=REPLACE
YT_OAUTH_CLIENT_SECRET=REPLACE
META_APP_ID=REPLACE
META_APP_SECRET=REPLACE

# --- Observability -----------------------------------------------------------
GRAFANA_DOMAIN=grafana.influaudit.com
GRAFANA_ADMIN_PASSWORD=REPLACE
# Where alerts are delivered. They go out through the SAME SMTP relay as the app.
ALERT_EMAIL=ops@influaudit.com
# Optional. Empty means email-only.
SLACK_WEBHOOK_URL=

# --- Backups -----------------------------------------------------------------
# age public key the nightly pg_dump is encrypted to (deploy/scripts/backup.sh).
BACKUP_AGE_RECIPIENT=age1REPLACE
