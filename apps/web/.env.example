# InfluAudit web (apps/web) configuration.
#
# All variables here are read ONLY on the server (route handlers, Server
# Components, middleware). None are exposed to the browser: there is no
# NEXT_PUBLIC_ variable, by design — the JWT and the backend base URL never
# reach client JS.

# --- Backend API ---
# Base URL of the Go backend, INCLUDING the /v1 base path from the OpenAPI
# `servers` entry. Server-only.
API_BASE_URL=http://localhost:8080/v1

# --- OAuth ---
# The absolute, publicly reachable base URL of THIS web app. Used to build the
# redirect_uri that Google sends the user back to
# (<APP_BASE_URL>/api/oauth/<provider>/callback). Must exactly match a redirect
# URI registered on the backend's Google OAuth client.
APP_BASE_URL=http://localhost:3000

# --- Session cookies ---
# When "true", session cookies are marked Secure (HTTPS only). Leave unset or
# "false" for local http development; set "true" in staging/prod.
SESSION_COOKIE_SECURE=false
