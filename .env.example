# InfluAudit backend configuration.
#
# Every variable is prefixed with INFLUAUDIT_ and nests with a double
# underscore (__), e.g. INFLUAUDIT_HTTP__ADDR maps to http.addr. Environment
# variables override any value from the optional YAML config file.
#
# All secret values below are PLACEHOLDERS. Never commit real credentials.
# Secrets are required only in prod; a dev machine may leave them unset.

# Deployment tier: dev | staging | prod
INFLUAUDIT_ENVIRONMENT=dev

# --- HTTP server ---
# Listen address (host:port; host may be omitted to bind all interfaces).
INFLUAUDIT_HTTP__ADDR=:8080
# Request read / write timeouts (Go duration syntax, e.g. 15s, 1m).
INFLUAUDIT_HTTP__READ_TIMEOUT=15s
INFLUAUDIT_HTTP__WRITE_TIMEOUT=15s

# --- Postgres ---
# Full DSN; contains the password, so treated as a secret.
INFLUAUDIT_POSTGRES__DSN=postgres://influaudit:CHANGE_ME@localhost:5432/influaudit?sslmode=disable

# --- Redis (cache + asynq broker) ---
INFLUAUDIT_REDIS__ADDR=127.0.0.1:6379
# Leave empty when Redis has no auth configured.
INFLUAUDIT_REDIS__PASSWORD=
INFLUAUDIT_REDIS__DB=0
# Every managed Redis (Memorystore, Azure Cache, ElastiCache in-transit, Upstash)
# accepts TLS connections only — Azure disables the plaintext port outright — so
# this is "true" in every deployed environment and false only against the local
# compose redis. config.Validate refuses to boot prod without it.
INFLUAUDIT_REDIS__TLS=false
# Overrides the certificate/SNI hostname. Leave empty to derive it from ADDR,
# which is correct for every managed service; set it only when connecting through
# a tunnel or by IP.
INFLUAUDIT_REDIS__TLS_SERVER_NAME=

# --- Master encryption key ---
# Base64 of exactly 32 raw bytes (AES-256). Decoded and length-checked at load.
# Generate a real one with: openssl rand -base64 32
#
# The value below is a placeholder committed to this repository. It is valid
# base64 and exactly 32 bytes, so it passes every structural check — which is
# why config.Validate rejects it BY VALUE in prod, along with the compose default
# key. Seals OAuth tokens at rest: rotating it requires re-encrypting
# oauth_connections, so it must be carried across a cloud migration unchanged.
INFLUAUDIT_CRYPTO__MASTER_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=

# --- Anthropic (LLM provider) ---
INFLUAUDIT_ANTHROPIC__API_KEY=sk-ant-REPLACE_ME

# --- Gotenberg (PDF rendering) ---
INFLUAUDIT_GOTENBERG__URL=http://localhost:3000

# --- ML service ---
INFLUAUDIT_ML__BASE_URL=http://localhost:8000
# Shared machine-to-machine bearer the ml server presents on the prediction-log
# ingest route (POST /v1/ml/predictions). The backend and the ml service must
# carry the SAME value. Empty in prod is a boot error: a deployment that cannot
# log predictions is a deployment that cannot retrain.
INFLUAUDIT_ML__SERVICE_TOKEN=dev-ml-service-token

# --- Object storage (S3-compatible) ---
# Dev uses LocalStack S3 (deploy/docker-compose.yml). The endpoint is the host
# address; inside compose the services reach it as http://localstack:4566. The
# access/secret keys are LocalStack's well-known dummies — not real credentials,
# and rejected by name in prod.
#
# This client speaks the S3 API over hand-rolled SigV4, so it works unchanged
# against AWS S3, Cloudflare R2, MinIO, and GCS in interop mode. Azure Blob is the
# one major store with no S3 face — see deploy/ARCHITECTURE.md.
INFLUAUDIT_STORAGE__ENDPOINT=http://localhost:4566
INFLUAUDIT_STORAGE__REGION=us-east-1
INFLUAUDIT_STORAGE__BUCKET=influaudit
INFLUAUDIT_STORAGE__ACCESS_KEY=test
INFLUAUDIT_STORAGE__SECRET_KEY=test
# Path-style addressing (endpoint/bucket/key). Required by LocalStack, MinIO and
# R2; AWS S3 accepts both and can set this to false for virtual-host style.
INFLUAUDIT_STORAGE__PATH_STYLE=true

# --- Transactional email (SMTP) ---
# SMTP, not a provider SDK: every transactional provider speaks it (Postmark,
# Resend, SendGrid, Mailgun, SES), so switching provider is a change of these
# values and nothing else. Dev points at mailpit (deploy/docker-compose.yml),
# which accepts everything and delivers nothing — read it at http://localhost:8025.
#
# TLS is one of: starttls (default, port 587) | implicit (port 465) | none.
# "none" is a local capture server only; config.Validate rejects it in prod,
# because authenticating to a relay in the clear gives the password away.
INFLUAUDIT_EMAIL__HOST=localhost
INFLUAUDIT_EMAIL__PORT=1025
INFLUAUDIT_EMAIL__USERNAME=
INFLUAUDIT_EMAIL__PASSWORD=
INFLUAUDIT_EMAIL__FROM=reports@influaudit.local
INFLUAUDIT_EMAIL__FROM_NAME=InfluAudit
INFLUAUDIT_EMAIL__TLS=none

# --- JWT signing (RS256) ---
# Provide EITHER a path to a PEM private key OR the PEM inline (not both).
INFLUAUDIT_JWT__PRIVATE_KEY_PATH=/etc/influaudit/jwt/private.pem
# INFLUAUDIT_JWT__PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...REPLACE_ME...\n-----END PRIVATE KEY-----"

# --- Razorpay (payments) ---
INFLUAUDIT_RAZORPAY__KEY_ID=rzp_test_REPLACE_ME
INFLUAUDIT_RAZORPAY__KEY_SECRET=REPLACE_ME_RAZORPAY_SECRET

# --- OpenTelemetry ---
# OTLP/gRPC exporter endpoint (host:port).
INFLUAUDIT_OTEL__EXPORTER_ENDPOINT=localhost:4317
